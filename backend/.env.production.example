# ── Required (server will NOT start without these) ──
NODE_ENV=production
PORT=5000

# MongoDB — use MongoDB Atlas connection string for production
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/zyra?retryWrites=true&w=majority

# Redis — use a managed Redis instance (Railway, Upstash, etc.)
REDIS_HOST=your-redis-host
REDIS_PORT=6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_STRONG_SECRET_HERE
JWT_EXPIRES_IN=7d

# Encryption key for stored provider API keys — generate with: openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_A_64_CHAR_HEX_STRING_HERE

# Frontend URL(s) for CORS — comma-separated if multiple
FRONTEND_URL=https://your-app.vercel.app

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id

# ── SMTP (required for email-based auth in production) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
