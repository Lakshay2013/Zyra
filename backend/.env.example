# ── Required (server will NOT start without these) ──
JWT_SECRET=generate-a-strong-random-string-here
MONGO_URI=mongodb://localhost:27018/ai-shield
ENCRYPTION_KEY=generate-a-64-char-hex-string-here-use-openssl-rand-hex-32

# ── Server Config ──
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Redis (for rate limiter + BullMQ workers) ──
REDIS_HOST=localhost
REDIS_PORT=6380

# ── JWT ──
JWT_EXPIRES_IN=7d

# ── Google OAuth (optional — Google login won't work without this) ──
GOOGLE_CLIENT_ID=your-google-client-id

# ── SMTP (optional in dev — required in production for OTP emails) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── Razorpay (required for payments) ──
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
